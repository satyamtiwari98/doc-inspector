{
  "name": "doc-inspector",
  "version": "1.0.0",
  "description": "Get page count, slide count, dimensions and metadata from PDF, DOCX and PPTX documents.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --dts --format cjs,esm --out-dir dist --clean",
    "prepare": "npm run build",
    "test": "vitest"
  },
  "keywords": [
    "pdf",
    "docx",
    "pptx",
    "pages",
    "slides",
    "metadata",
    "document"
  ],
  "author": "Satyam Tiwari",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/satyamtiwari98/doc-inspector.git"
  },
  "homepage": "https://github.com/satyamtiwari98/doc-inspector",
  "bugs": {
    "url": "https://github.com/satyamtiwari98/doc-inspector/issues"
  },
  "dependencies": {
    "fast-xml-parser": "^5.9.3",
    "file-type": "^22.0.1",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
